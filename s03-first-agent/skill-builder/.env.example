# Copy to .env and fill in. .env is gitignored at repo root.

# Google Gemini API key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model to use. Free-tier friendly defaults:
#   gemini-2.5-flash-lite   (recommended, fast, cheap)
#   gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash-lite

# Seconds to sleep before each LLM call, to stay under free-tier 15 RPM.
# Set to 0 if you have a paid key.
THROTTLE_SECONDS=4

# Where skills get written. Defaults to ~/.claude/skills.
# Point at a scratch dir for safe dry-runs.
SKILLS_DIR=
